import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Logotype from '../components/Logotype.astro';
import Footer from '../components/Footer.astro';
import Favicon from '../components/Favicon.astro';

---

<html lang="en">

	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle} | {author}</title>
		<meta name="author" content= {author} />
		<meta name="description" content={pageDescription}/>
		<a rel="me" href="https://typo.social/@annie"></a>
		<Favicon />
		<Logotype />
		<link rel="stylesheet" href="https://use.typekit.net/eqn1sld.css">
	</head>

<body>
	<div class="page-container">
	<Navigation />
	<main class="grid-container-info">



			<!-------------- INTRO -------------->

			<section id="info-intro">
				<!--<img src="/images/headshot.jpg">
								<img src="https://res.cloudinary.com/dzv7ytxjh/image/upload/f_auto,q_auto/v1740707709/100_0920__edit_tsqq8o.jpg">
							-->
				<img src="https://res.cloudinary.com/dzv7ytxjh/image/upload/v1747809612/54516764187_789bafa66e_k_brijbf.jpg">
				
				
				<aside class="design-services">
					<h4>Design Services</h4>
					<ul>
						<li>✺ Logotypes</li>
